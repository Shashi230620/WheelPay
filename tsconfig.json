{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
     "baseUrl": ".",
    "paths": {
      "app-Shared/*":["Src/Shared/*"],
      "app-Customer/*":["Src/Customer_Modules/*"],
      "app-Driver/*":["Src/Driver_Modules/*"],
    },
    "types": ["jest"],
    "strict": true,
    "noImplicitAny": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"],
  
}
